# Legacy single variable (still supported):
# REACT_APP_API_URL=http://localhost:8080/api/v1

# Preferred versioned API configuration:
REACT_APP_API_ORIGIN=http://localhost:8080
REACT_APP_API_BASE_PATH=/api
REACT_APP_API_VERSION=v1

# true (default) uses local mock API modules. Set to false to call backend API.
REACT_APP_USE_MOCK_API=true
